# ==================== 模型配置 ====================
# 嵌入模型（推荐）
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# 重排序模型
RERANKER_MODEL=BAAI/bge-reranker-base

# 大语言模型（Ollama本地模型）
LLM_MODEL=qwen2.5:3b

# 运行设备（cpu/cuda/mps）
DEVICE=cpu

# ==================== 知识库配置 ====================
# 知识库文件夹路径（用户需要自己修改）
KNOWLEDGE_BASE_DIR=./data/knowledge_base

# 向量数据库存储路径
CHROMA_DB_PATH=./data/chroma_db

# 分块大小
CHUNK_SIZE=500

# 分块重叠
CHUNK_OVERLAP=50

# 分块策略（recursive/markdown）
CHUNK_STRATEGY=recursive

# 支持的文件格式
SUPPORTED_FORMATS=.pdf,.docx,.md,.txt

# ==================== 检索配置 ====================
# 是否使用混合检索（向量+BM25）
USE_MIXED_RETRIEVAL=True

# 是否使用重排序
USE_RERANKER=True

# 是否使用上下文压缩
USE_CONTEXT_COMPRESSION=False

# 宽召回数量（重排序前）
TOP_K_WIDE=10

# 最终召回数量
TOP_K_FINAL=3

# 向量检索权重
VECTOR_WEIGHT=0.7

# BM25检索权重
BM25_WEIGHT=0.3

# ==================== 对话配置 ====================
# 是否支持多轮对话
USE_MULTI_TURN=True

# 大模型温度参数（0.0-1.0，越小越保守）
LLM_TEMPERATURE=0.1

# ==================== Streamlit配置 ====================
# 页面标题
PAGE_TITLE=完整RAG问答系统

# 页面图标
PAGE_ICON=📚

# 页面布局（wide/centered）
LAYOUT=wide
